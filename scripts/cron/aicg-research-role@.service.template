[Unit]
Description=AICG per-role research: %i

[Service]
Type=oneshot
Environment=PATH={PATH}
Environment=HOME={HOME}
ExecStartPre=/bin/mkdir -p {LOG_DIR}
ExecStart={RUNNER_DIR}/scripts/aicg-org-job.sh research-role %i --workspace {WORKSPACE} --manifest {MANIFEST} --state-dir {STATE_DIR}
StandardOutput=append:{LOG_DIR}/research-role-%i.log
StandardError=append:{LOG_DIR}/research-role-%i.log
